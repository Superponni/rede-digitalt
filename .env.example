# Kopier til .env.local og fyll inn. Sett de samme i Vercel (alle miljøer).

# Sanity-prosjekt — offentlig (NEXT_PUBLIC), trygt i nettleser-bundelen.
NEXT_PUBLIC_SANITY_PROJECT_ID=tqfezovu
NEXT_PUBLIC_SANITY_DATASET=production

# Read-only token for live forhåndsvisning av utkast (Presentation).
# MÅ være Viewer-rolle (kun lesing): next-sanity sender tokenet til nettleseren
# når draft-mode er på (bak preview-secret), så et token med skrive-/admin-
# rettigheter ville vært en sikkerhetsrisiko. Opprett under
# sanity.io/manage → prosjekt → API → Tokens → rolle «Viewer».
# Uten dette virker ikke forhåndsvisning (kun publisert innhold vises), og
# /api/draft-mode/enable svarer 500.
SANITY_API_READ_TOKEN=
